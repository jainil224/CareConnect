{
  "name": "careconnect-health-orchestrator",
  "version": "1.0.0",
  "description": "AI-Driven Home Health Orchestrator",
  "main": "index.js",
  "scripts": {
    "start": "set PORT=3076 && react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server/index.js",
    "flask": "cd ML-model/ECG && python app.py",
    "dev:local": "concurrently -n \"React,Flask\" -c \"cyan,green\" \"npm run start\" \"npm run flask\"",
    "dev:docker": "docker-compose up --build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^1.16.2",
    "axios": "^1.3.0",
    "bcryptjs": "^2.4.0",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "firebase": "^12.13.0",
    "framer-motion": "^12.39.0",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.263.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.2.0",
    "tesseract.js": "^4.0.0",
    "twilio": "^4.19.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
